# Exemplo de variáveis de ambiente
# Copie este arquivo para .env e preencha com seus valores

# Supabase (Banco de dados)
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_KEY=sua-chave-supabase

# Telegram Bot
TELEGRAM_TOKEN=seu-telegram-token
TELEGRAM_GROUP_ID=seu-chat-id

# Google AI (Gemini)
GOOGLE_API_KEY=sua-chave-google-ai

# Configuração do App
APP_SECRET=chave-secreta-aleatoria
PORT=8080
